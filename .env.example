# ============================================================
# SaaS Research Platform — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# ── Required ────────────────────────────────────────────────

# OpenAI API key (gpt-4o for extraction, gpt-4o-mini for classification)
OPENAI_API_KEY=sk-...

# Firecrawl API key — https://firecrawl.dev
FIRECRAWL_API_KEY=fc-...

# Tavily web search API key — https://tavily.com
TAVILY_API_KEY=tvly-...

# ── Optional ─────────────────────────────────────────────────

# Override the extraction model (default: gpt-4o)
# OPENAI_MODEL_EXTRACTION=gpt-4o

# Override the classification model (default: gpt-4o-mini)
# OPENAI_MODEL_CLASSIFICATION=gpt-4o-mini

# GitHub personal access token for MCP detection searches
# Increases GitHub API rate limit from 60 to 5000 req/hr
# GITHUB_TOKEN=ghp_...

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
# LOG_LEVEL=INFO

# Database path override (default: data/research.db)
# DATABASE_PATH=data/research.db

# Cache directory override (default: data/cache)
# CACHE_DIR=data/cache

# Reports output directory (default: reports)
# REPORTS_DIR=reports
